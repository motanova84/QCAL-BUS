# ── Core ──────────────────────────────────────────────────────────────────────
QCAL_SYNC_INTERVAL_SECONDS=60
QCAL_GLOBAL_THRESHOLD=0.999999
QCAL_SATURATION_CYCLES=3
QCAL_EMISSION_BASE=888
QCAL_LEDGER_TAIL=50

# ── Modo de operación ─────────────────────────────────────────────────────────
# 0 = simulado (sin conexiones externas), 1 = real (conecta a nodos MCP)
QCAL_REAL_TESTS=0

# ── Frecuencia de referencia ──────────────────────────────────────────────────
QCAL_F0_HZ=141.7001

# ── URLs de nodos MCP (solo necesarias cuando QCAL_REAL_TESTS=1) ─────────────
# Formato: QCAL_NODE_<MCP_ID_EN_MAYUSCULAS_CON_GUIONES_COMO_GUIONES_BAJOS>_URL

# Capa: núcleo
QCAL_NODE_RIEMANN_MCP_SERVER_URL=https://riemann-mcp.example.com
QCAL_NODE_141_HZ_URL=https://141hz-mcp.example.com

# Capa: cuerpo
QCAL_NODE_NAVIER_MCP_SERVER_URL=https://navier-mcp.example.com
QCAL_NODE_P_NP_MCP_SERVER_URL=https://pnp-mcp.example.com

# Capa: mente
QCAL_NODE_RAMSEY_QCAL_URL=https://ramsey-mcp.example.com
QCAL_NODE_BSD_MCP_SERVER_URL=https://bsd-mcp.example.com

# Capa: vida
