# QCAL-EPR Mesh Bus — Environment Variables
# Copy this file to .env and fill in your values

# Reference frequency of the ecosystem (Hz)
F0_REFERENCE=141.7001

# Enable real MCP node tests (set to 1 in production)
QCAL_REAL_TESTS=0

# Port for the mesh dashboard
DASHBOARD_PORT=8505

# Coherence threshold for πCODE-888 emission
PSI_EMISSION_THRESHOLD=0.999999

# Number of consecutive cycles above threshold required before emission
EMISSION_CYCLES_REQUIRED=3

# Default MCP host (override per node in NODE_CATALOG.json)
MCP_DEFAULT_HOST=localhost
MCP_DEFAULT_PORT=8506
