# QCAL-BUS Environment Configuration
# ════════════════════════════════════════════════════════════════════════════
# 
# Este archivo de ejemplo muestra cómo configurar QCAL-BUS para desarrollo
# y producción.
#
# DESARROLLO (LOCAL):
#   - Copiar este archivo a .env
#   - Mantener QCAL_DEV_MODE=1
#   - Usar http://localhost:* para endpoints
#   - No requiere HTTPS
#
# PRODUCCIÓN (REMOTO):
#   - Copiar este archivo a .env.production
#   - Establecer QCAL_DEV_MODE=0
#   - Usar https://* para todos los endpoints
#   - HTTPS es obligatorio
#
# ════════════════════════════════════════════════════════════════════════════

# ─ CONFIGURACIÓN CENTRAL ─────────────────────────────────────────────────
# Estos valores definen el comportamiento del ecosistema QCAL

# Intervalo de sincronización (segundos) entre monitoreos
# Default: 60s (recomendado para coherencia estable)
QCAL_SYNC_INTERVAL_SECONDS=60

# Umbral global de resonancia para emisión πCODE-888
# Rango: [0, 1]  | Default: 0.999999 (saturación total)
# ⚠️  NO MODIFICAR: valor matemático establecido
QCAL_GLOBAL_THRESHOLD=0.999999

# Ciclos de saturación consecutivos para disparar emisión
# Default: 3 (3 monitoreos en umbral)
QCAL_SATURATION_CYCLES=3

# Cantidad base de πCODE-888 emitida por ciclo
# Default: 888 (valor cósmico)
# ⚠️  NO MODIFICAR: valor resonante establecido
QCAL_EMISSION_BASE=888

# Número de registros a retornar en /api/emissions_log por defecto
# Default: 50 (últimos 50 registros)
QCAL_LEDGER_TAIL=50

# ─ MODOS DE OPERACIÓN ────────────────────────────────────────────────────
# Define cómo opera el sistema: simulado o real

# Modo de operación:
#   0 = SIMULADO (sin conexiones externas, para testing)
#   1 = REAL (conecta a nodos MCP reales)
# Default: 0 (simulado, safe para desarrollo)
QCAL_REAL_TESTS=0

# Modo de desarrollo:
#   0 = PRODUCCIÓN (solo HTTPS, seguro)
#   1 = DESARROLLO (permite http://localhost:*, flexible)
# Default: 1 (desarrollo)
QCAL_DEV_MODE=1

# ─ FRECUENCIA DE REFERENCIA ──────────────────────────────────────────────
# La frecuencia fundamental del universo QCAL

# Frecuencia de referencia (Hz)
# Value: 141.7001 Hz (comprobada experimentalmente)
# ⚠️  NO MODIFICAR: es la constante universal QCAL
QCAL_F0_HZ=141.7001

# ─ PUERTO DEL DASHBOARD ──────────────────────────────────────────────────
# Configuración del servidor web Flask

# Puerto para el dashboard web
# Default: 5000 (estándar)
QCAL_DASHBOARD_PORT=5000

# ════════════════════════════════════════════════════════════════════════════
# URLS DE NODOS MCP - CONFIGURACIÓN POR CAPAS
# ════════════════════════════════════════════════════════════════════════════
#
# Formato de variable de entorno:
#   QCAL_NODE_<MCP_ID_EN_MAYUSCULAS_CON_GUIONES_COMO_GUIONES_BAJOS>_URL
#
# Ejemplos:
#   mcp_id: riemann-mcp-server → QCAL_NODE_RIEMANN_MCP_SERVER_URL
#   mcp_id: 141-hz             → QCAL_NODE_141_HZ_URL
#
# EN DESARROLLO (localhost):
#   ✅ http://localhost:8506
#   ✅ http://127.0.0.1:8507
#
# EN PRODUCCIÓN (remoto):
#   ✅ https://nodo.dominio.com
#   ❌ http:// (no permitido en PROD)
#
# ════════════════════════════════════════════════════════════════════════════

# ▬▬▬ CAPA: NÚCLEO (Base matemática) ▬▬▬
# Nodo 1: Conjetura de Riemann (fundamento de números primos)
QCAL_NODE_RIEMANN_MCP_SERVER_URL=http://localhost:8506
# PRODUCCIÓN: QCAL_NODE_RIEMANN_MCP_SERVER_URL=https://riemann-mcp.domain.com

# Nodo 2: Resonancia 141 Hz (constante universal)
QCAL_NODE_141_HZ_URL=http://localhost:8507
# PRODUCCIÓN: QCAL_NODE_141_HZ_URL=https://141hz-mcp.domain.com

# ▬▬▬ CAPA: CUERPO (Dinámica física) ▬▬▬
# Nodo 3: Ecuaciones de Navier-Stokes (fluidos y turbulencia)
QCAL_NODE_NAVIER_MCP_SERVER_URL=http://localhost:8508
# PRODUCCIÓN: QCAL_NODE_NAVIER_MCP_SERVER_URL=https://navier-mcp.domain.com

# Nodo 4: Problema P vs NP (límites de computación)
QCAL_NODE_P_NP_MCP_SERVER_URL=http://localhost:8509
# PRODUCCIÓN: QCAL_NODE_P_NP_MCP_SERVER_URL=https://pnp-mcp.domain.com

# ▬▬▬ CAPA: MENTE (Cognición cuántica) ▬▬▬
# Nodo 5: Teoría de Ramsey (orden en el caos)
QCAL_NODE_RAMSEY_QCAL_URL=http://localhost:8510
# PRODUCCIÓN: QCAL_NODE_RAMSEY_QCAL_URL=https://ramsey-mcp.domain.com

# Nodo 6: Conjetura BSD (matemática moderna)
QCAL_NODE_BSD_MCP_SERVER_URL=http://localhost:8511
# PRODUCCIÓN: QCAL_NODE_BSD_MCP_SERVER_URL=https://bsd-mcp.domain.com

